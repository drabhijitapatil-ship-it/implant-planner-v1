{
  "expo": {
    "name": "dental-phase-app",
    "slug": "dental-phase-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dental-phase-app",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/364fac6d-f5b1-447e-88e5-f27bb0a027e6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dental.phaseapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.dental.phaseapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2196F3"
        }
      ],
      "./plugins/withAndroidNetworkConfig",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photo library to upload radiographs and clinical images.",
          "cameraPermission": "Allow access to your camera to capture radiographs and clinical images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "364fac6d-f5b1-447e-88e5-f27bb0a027e6"
      },
      "router": {},
      "backendUrl": "https://implant-app-r-1774251381.emergent.host"
    },
    "owner": "abhijitapatil"
  }
}
